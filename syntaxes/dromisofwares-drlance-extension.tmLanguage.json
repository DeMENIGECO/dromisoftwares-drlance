{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Dromi",
  "scopeName": "source.dromi",

  "patterns": [
    { "include": "#keywords" },
    { "include": "#strings" }
  ],

  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dromi",
          "match": "\\b(if|elif|else)\\b"
        },
        {
          "name": "keyword.control.dromi",
          "match": "\\b(loop)\\b"
        },
        {
          "name": "entity.name.function.dromi",
          "match": "\\bfunction\\s+[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.dromi",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.dromi",
          "match": "\\\\."
        }
      ]
    }
  }
}